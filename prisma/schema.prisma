generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model User {
  id            String         @id @default(uuid())
  email         String         @unique
  phone         String?        @unique
  name          String
  role          String         @default("patient") // patient, doctor, admin
  abha_id       String?        @unique // ABDM field
  createdAt     DateTime       @default(now())
  
  doctorProfile Doctor?
  appointments  Appointment[]
  prescriptions Prescription[]
  phr_records   PHR_Record[]
}

model Doctor {
  id                 String   @id @default(uuid())
  user               User     @relation(fields: [userId], references: [id])
  userId             String   @unique
  nmcLicenseNo       String?  @unique
  specialty          String
  consultation_fee   Decimal  
  verification_status String  @default("pending") // pending, verified
  availability       String?  // JSON string
  appointments       Appointment[]
  prescriptions      Prescription[]
}

model Appointment {
  id                 String            @id @default(uuid())
  patient            User              @relation(fields: [patientId], references: [id])
  patientId          String
  doctor             Doctor            @relation(fields: [doctorId], references: [id])
  doctorId           String
  slotStart          DateTime
  slotEnd            DateTime
  type               String            // in-clinic, virtual
  status             String            @default("pending") // pending, confirmed, completed, cancelled
  prescriptions      Prescription[]
  consultation       Consultation?
}

model Consultation {
  id                 String       @id @default(uuid())
  appointment        Appointment  @relation(fields: [appointmentId], references: [id])
  appointmentId      String       @unique
  video_room_id      String?
  recording_consent  Boolean      @default(false)
  ai_summary         String?      
}

model Prescription {
  id               String      @id @default(uuid())
  appointment      Appointment @relation(fields: [appointmentId], references: [id])
  appointmentId    String
  doctor           Doctor      @relation(fields: [doctorId], references: [id])
  doctorId         String
  patient          User        @relation(fields: [patientId], references: [id])
  patientId        String
  medications      String      // JSON payload
  validTill        DateTime
}

model PHR_Record {
  id               String   @id @default(uuid())
  patientId        String
  user             User     @relation(fields: [patientId], references: [id])
  fhir_bundle      String   // Encrypted HL7 FHIR payload
  abha_linked      Boolean  @default(false)
  createdAt        DateTime @default(now())
}
